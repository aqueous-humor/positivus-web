---
import Container from "../primitives/Container.astro";
import Button from "../primitives/Button.astro";
import Logo from "../../assets/logo-default.svg";
---

<header class="py-15">
  <Container>
    <div class="flex items-center justify-between regular-text">
      <!-- Logo -->
      <Logo height={56} />

      <!-- Nav -->
      <nav class="hidden md:flex flex-row items-center gap-10">
        <a href="#">About us</a>
        <a href="#">Services</a>
        <a href="#">Use Cases</a>
        <a href="#">Pricing</a>
        <a href="#">Blog</a>
        <!-- CTA -->
        <div class="hidden md:block">
          <Button variant="outline">Request a quote</Button>
        </div>
      </nav>

      <!-- Mobile -->
      <button class="md:hidden text-2xl">☰</button>
    </div>
  </Container>
</header>
