---
import Container from "../primitives/Container.astro";
import Button from "../primitives/Button.astro";
import LogoTray from "../ui/LogoTray.astro";
---

<section class="flex flex-col gap-20">
  <Container class="gap-20">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- LEFT CONTENT -->
      <div class="flex flex-col gap-[35px] max-w-[531px]">
        <h1 class="heading1">Navigating the digital landscape for success</h1>
        <!-- <Label variant="primary" as="h1" text="Search engine optimization " /> -->

        <p class="regular-text text-gray-600 max-w-[500px]">
          Our digital marketing agency helps businesses grow and succeed online
          through a range of services including SEO, PPC, social media
          marketing, and content creation.
        </p>

        <div class="">
          <Button variant="dark">Book a consultation</Button>
        </div>
      </div>

      <!-- RIGHT IMAGE -->
      <div class="flex justify-center md:justify-end">
        <img
          src="/illustrations/hero-illustration.jpg"
          alt="Digital marketing illustration"
          class="w-full"
        />
      </div>
    </div>
  </Container>
  <LogoTray />
</section>
